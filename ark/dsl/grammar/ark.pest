// ARK DSL Grammar — pest PEG.
// Mirrors the working Lark grammar in tools/parser/ark_grammar.lark.
//
// Conventions:
//   _ prefix (`_{ ... }`)   — silent rule, removed from parse tree
//   @ prefix (`@{ ... }`)   — atomic, no whitespace or inner rules
//   $ prefix (`${ ... }`)   — compound atomic, no WS but inner rules visible
//   !... prefix (`!{ ... }`) — non-atomic (WS allowed inside)

WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT    = _{ "//" ~ (!"\n" ~ ANY)* | "/*" ~ (!"*/" ~ ANY)* ~ "*/" }

// ============================================================
// TOP LEVEL
// ============================================================

file = { SOI ~ (import_stmt | item)* ~ EOI }

import_stmt = { "import" ~ dotted_path }

item = _{
    abstraction_def
  | class_def
  | instance_def
  | island_def
  | bridge_def
  | registry_def
  | expression_def
  | predicate_def
  | verify_def
  | role_def
  | studio_def
  | command_def
  | hook_def
  | rule_def
  | template_def
  | evolution_target_def
  | eval_dataset_def
  | fitness_function_def
  | optimizer_def
  | benchmark_gate_def
  | evolution_run_def
  | constraint_def
  | agent_def
  | platform_def
  | gateway_def
  | execution_backend_def
  | skill_def
  | learning_config_def
  | cron_task_def
  | model_config_def
  | diagram_def
  | preview_def
  | annotation_def
  | visual_review_def
  | screenshot_def
  | visual_search_def
  | render_config_def
}

// ============================================================
// FOUR PRIMITIVES: @in, @out, #process, $data
// ============================================================

in_port      = { "@in" ~ "{" ~ typed_field_list? ~ "}" }
out_port     = { "@out" ~ empty_meta? ~ "{" ~ typed_field_list? ~ "}" }
empty_meta   = { "[" ~ meta_pair_list? ~ "]" }
process_rule = { "#process" ~ meta_brackets? ~ "{" ~ process_body ~ "}" }
data_field   = { "$data" ~ ident ~ ":" ~ type_expr ~ constraint? ~ default_value? }

process_body = { process_stmt* }
process_stmt = _{
    pre_stmt
  | post_stmt
  | requires_stmt
  | description_stmt
  | for_all_stmt
  | condition_stmt
  | assignment
  | expression
}
pre_stmt      = { "pre:" ~ expression }
post_stmt     = { "post:" ~ expression }
requires_stmt = { "requires:" ~ expression }

// ============================================================
// ENTITIES
// ============================================================

abstraction_def = { "abstraction" ~ ident ~ inherits? ~ "{" ~ entity_body ~ "}" }
class_def       = { "class" ~ ident ~ inherits? ~ "{" ~ entity_body ~ "}" }

entity_body   = { entity_member* }
entity_member = _{
    in_port
  | out_port
  | process_rule
  | data_field
  | invariant_stmt
  | temporal_stmt
  | description_stmt
}

inherits = { ":" ~ ident_list }

instance_def = { "instance" ~ ident ~ ":" ~ ident ~ "{" ~ assignment* ~ "}" }

// ============================================================
// ISLANDS
// ============================================================

island_def    = { "island" ~ ident ~ "{" ~ island_body ~ "}" }
island_body   = { island_member* }
island_member = _{
    strategy_stmt
  | memory_stmt
  | contains_stmt
  | description_stmt
  | in_port
  | out_port
  | process_rule
  | class_def
  | data_field
  | invariant_stmt
  | temporal_stmt
}

// ============================================================
// BRIDGES
// ============================================================

bridge_def     = { "bridge" ~ ident ~ "{" ~ from_stmt ~ to_stmt ~ contract_block? ~ "}" }
from_stmt      = { "from:" ~ dotted_path_or_ident }
to_stmt        = { "to:" ~ dotted_path_or_ident }
contract_block = { "contract" ~ "{" ~ contract_member* ~ "}" }
contract_member = _{ invariant_stmt | temporal_stmt }

// ============================================================
// REGISTRY
// ============================================================

registry_def  = { "registry" ~ ident ~ "{" ~ register_stmt* ~ "}" }
register_stmt = { "register" ~ ident ~ "{" ~ meta_pair_list? ~ "}" }

// ============================================================
// VERIFY
// ============================================================

verify_def = { "verify" ~ ident ~ "{" ~ check_stmt* ~ "}" }
check_stmt = { "check" ~ ident ~ ":" ~ expression }

// ============================================================
// EXPRESSION & PREDICATE ITEMS
// ============================================================

expression_def = { "expression" ~ ident ~ "{" ~ expression_body ~ "}" }
predicate_def  = { "predicate"  ~ ident ~ "{" ~ predicate_body  ~ "}" }

expression_body = { "in:" ~ typed_field_list ~ "out:" ~ type_expr ~ "chain:" ~ expression }
predicate_body  = { "in:" ~ typed_field_list ~ "check:" ~ expression }

// ============================================================
// STATEMENTS
// ============================================================

strategy_stmt    = { "strategy:" ~ ident }
memory_stmt      = { "memory:" ~ "{" ~ memory_entry ~ ("," ~ memory_entry)* ~ "}" }
memory_entry     = { ident ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }
contains_stmt    = { "contains:" ~ "[" ~ ident_list ~ "]" }
description_stmt = { "description:" ~ string_literal }
invariant_stmt   = { "invariant:" ~ expression }
temporal_stmt    = { "temporal:" ~ expression }
assignment       = { dotted_path_or_ident ~ "=" ~ expression }

for_all_stmt   = { "for_all" ~ ident ~ "as" ~ ident ~ ("where" ~ expression)? ~ ":" ~ for_all_tail }
for_all_tail   = _{ process_block | assignment | expression }
process_block  = { "{" ~ process_body ~ "}" }
condition_stmt = { "condition" ~ expression ~ ":" ~ condition_tail }
condition_tail = _{ process_block | assignment }

// ============================================================
// EXPRESSIONS — precedence climbing, left-folded in the transformer
// ============================================================

expression = { pipe_expr }
pipe_expr  = { or_expr ~ ("|>" ~ pipe_stage)* }
pipe_stage    = { pipe_fn_ident ~ call_tail? }
pipe_fn_ident = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* ~ ("-" ~ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")*)* }

or_expr  = { and_expr ~ ("or" ~ and_expr)* }
and_expr = { cmp_expr ~ ("and" ~ cmp_expr)* }
cmp_expr = { add_expr ~ (cmp_op ~ add_expr)* }
add_expr = { mul_expr ~ (add_op ~ mul_expr)* }
mul_expr = { unary_expr ~ (mul_op ~ unary_expr)* }

unary_expr = _{ temporal_expr | not_expr | atom }
temporal_expr = { temporal_op ~ unary_expr }
not_expr      = { "not" ~ unary_expr }

// IMPORTANT: order matters — "==" before "=", "<=" before "<".
// "in" must not match the prefix of identifiers like "invariant".
cmp_op      = @{ "==" | "!=" | "<=" | ">=" | "→" | "<" | ">" | "=" | ("in" ~ !(ASCII_ALPHANUMERIC | "_" | "'")) }
add_op      = @{ "+" | "-" }
mul_op      = @{ "*" | "/" | "%" }
temporal_op = @{ "□" | "◇" | "○" | "¬" | "∧" | "∨" }

atom = _{
    paren_expr
  | prop_ref
  | array_expr
  | for_all_expr
  | number_expr
  | string_expr
  | true_expr
  | false_expr
  | var_ref
  | idx_ref
  | nested_ref
  | path_call_expr
}

paren_expr  = { "(" ~ expression ~ ")" }
array_expr  = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }
number_expr = { number }
string_expr = { string_literal }
true_expr   = { "true" }
false_expr  = { "false" }

for_all_expr = { "for_all" ~ ident ~ "as" ~ ident ~ ("where" ~ expression)? ~ ":" ~ (process_block | expression) }

// Parameter references (Expressif-style sigils)
var_ref    = ${ "@" ~ ident }
prop_ref   = { "[" ~ ident ~ ("." ~ ident)+ ~ "]" }
idx_ref    = ${ "#" ~ ident ~ "[" ~ number ~ "]" }
nested_ref = { "{" ~ expression ~ "}" }

// path_call_expr covers:
//   foo                 — bare ident
//   foo.bar.baz         — dotted path
//   foo(args)           — function call on ident
//   foo.bar(args)       — function call on dotted path
// Compound-atomic so the dots and identifiers are glued.
path_call_expr = ${ ident ~ ("." ~ ident)* ~ call_tail? }
call_tail      = !{ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

// ============================================================
// TYPES
// ============================================================

type_expr    = _{ generic_type | array_type | named_type }
generic_type = { ident ~ "<" ~ type_expr ~ ">" }
array_type   = { "[" ~ type_expr ~ (";" ~ number)? ~ "]" }
named_type   = { ident }

// ============================================================
// CONSTRAINTS
// ============================================================

constraint       = _{ range_constraint | enum_constraint }
range_constraint = { "[" ~ expression ~ ".." ~ expression ~ "]" }
enum_constraint  = { "{" ~ expression ~ ("," ~ expression)* ~ "}" }
default_value    = { "=" ~ expression }

// ============================================================
// META
// ============================================================

meta_brackets  = { "[" ~ meta_pair_list? ~ "]" }
meta_pair_list = { meta_pair ~ ("," ~ meta_pair)* }
meta_pair      = { ident ~ ":" ~ expression }

// ============================================================
// LISTS & PATHS
// ============================================================

typed_field_list = { typed_field ~ ("," ~ typed_field)* }
typed_field      = { ident ~ ":" ~ type_expr }
ident_list       = { ident ~ ("," ~ ident)* }

// Compound atomic: no whitespace around dots.
dotted_path_or_ident = ${ ident ~ ("." ~ ident)* }
dotted_path          = ${ ident ~ ("." ~ ident)+ }

// ============================================================
// STUDIO HIERARCHY
// ============================================================

// 1. role — specialist role definition
role_def  = { "role" ~ ident ~ inherits? ~ "{" ~ role_body ~ "}" }
role_body = { role_member* }
role_member = _{
    tier_stmt
  | responsibility_stmt
  | escalates_to_stmt
  | skills_stmt
  | tools_stmt
  | data_field
  | description_stmt
  | in_port
  | out_port
  | process_rule
}

tier_stmt           = { "tier:" ~ expression }
responsibility_stmt = { "responsibility:" ~ string_literal }
escalates_to_stmt   = { "escalates_to:" ~ ident }
skills_stmt         = { "skills:" ~ "[" ~ ident_list ~ "]" }
tools_stmt          = { "tools:" ~ "[" ~ ident_list ~ "]" }

// 2. studio — island grouping roles into tiers
studio_def  = { "studio" ~ ident ~ "{" ~ studio_body ~ "}" }
studio_body = { studio_member* }
studio_member = _{
    tier_group
  | contains_stmt
  | description_stmt
  | data_field
  | invariant_stmt
  | process_rule
  | bridge_def
}

tier_group = { "tier" ~ expression ~ "{" ~ ident_list ~ "}" }

// 3. command — workflow slash-command binding
command_def  = { "command" ~ ident ~ "{" ~ command_body ~ "}" }
command_body = { command_member* }
command_member = _{
    phase_stmt
  | prompt_stmt
  | role_ref_stmt
  | output_stmt
  | description_stmt
  | data_field
}

phase_stmt    = { "phase:" ~ ident }
prompt_stmt   = { "prompt:" ~ string_literal }
role_ref_stmt = { "role:" ~ ident }
output_stmt   = { "output:" ~ ident }

// 4. hook — event-driven rule
hook_def  = { "hook" ~ ident ~ "{" ~ hook_body ~ "}" }
hook_body = { hook_member* }
hook_member = _{
    event_stmt
  | pattern_stmt
  | action_stmt
  | description_stmt
  | data_field
}

event_stmt   = { "event:" ~ ident }
pattern_stmt = { "pattern:" ~ string_literal }
action_stmt  = { "action:" ~ string_literal }

// 5. rule — path-scoped policy
rule_def  = { "rule" ~ ident ~ "{" ~ rule_body ~ "}" }
rule_body = { rule_member* }
rule_member = _{
    path_stmt
  | constraint_stmt_rule
  | severity_stmt
  | description_stmt
  | data_field
}

path_stmt           = { "path:" ~ string_literal }
constraint_stmt_rule = { "constraint:" ~ string_literal }
severity_stmt       = { "severity:" ~ ident }

// 6. template — document skeleton
template_def  = { "template" ~ ident ~ "{" ~ template_body ~ "}" }
template_body = { template_member* }
template_member = _{
    sections_stmt
  | bound_to_stmt
  | description_stmt
  | data_field
}

sections_stmt = { "sections:" ~ "[" ~ string_list ~ "]" }
bound_to_stmt = { "bound_to:" ~ ident }
string_list   = { string_literal ~ ("," ~ string_literal)* }

// ============================================================
// EVOLUTION SYSTEM
// ============================================================

// 1. evolution_target_def — model or artifact to be evolved
evolution_target_def  = { "evolution_target" ~ ident ~ "{" ~ evolution_target_body ~ "}" }
evolution_target_body = { evolution_target_member* }
evolution_target_member = _{
    tier_stmt
  | file_ref_stmt
  | constraints_block
  | description_stmt
  | data_field
}

file_ref_stmt    = { "file_ref:" ~ string_literal }
constraints_block = { "constraints" ~ "{" ~ constraint_item* ~ "}" }
constraint_item  = { constraint_item_member+ }
constraint_item_member = _{
    name_stmt
  | type_stmt
  | threshold_stmt
  | enforcement_stmt
}

name_stmt        = { "name:" ~ string_literal }
type_stmt        = { "type:" ~ ident }
threshold_stmt   = { "threshold:" ~ expression }
enforcement_stmt = { "enforcement:" ~ ident }

// 2. eval_dataset_def — dataset used to evaluate evolved artifacts
eval_dataset_def  = { "eval_dataset" ~ ident ~ "{" ~ eval_dataset_body ~ "}" }
eval_dataset_body = { eval_dataset_member* }
eval_dataset_member = _{
    source_stmt
  | split_stmt
  | scoring_rubric_stmt
  | description_stmt
  | data_field
}

source_stmt        = { "source:" ~ string_literal }
split_stmt         = { "split:" ~ "{" ~ split_entry ~ ("," ~ split_entry)* ~ ","? ~ "}" }
split_entry        = { ident ~ ":" ~ number }
scoring_rubric_stmt = { "scoring_rubric:" ~ string_literal }

// 3. fitness_function_def — multi-dimensional scoring function
fitness_function_def  = { "fitness_function" ~ ident ~ "{" ~ fitness_function_body ~ "}" }
fitness_function_body = { fitness_function_member* }
fitness_function_member = _{
    dimension_stmt
  | aggregation_stmt
  | description_stmt
  | data_field
}

dimension_stmt   = { "dimension" ~ ident ~ "{" ~ dimension_body ~ "}" }
dimension_body   = { dimension_member* }
dimension_member = _{
    weight_stmt
  | metric_stmt
}
weight_stmt      = { "weight:" ~ number }
metric_stmt      = { "metric:" ~ string_literal }
aggregation_stmt = { "aggregation:" ~ ident }

// 4. optimizer_def — search/optimization engine configuration
optimizer_def  = { "optimizer" ~ ident ~ "{" ~ optimizer_body ~ "}" }
optimizer_body = { optimizer_member* }
optimizer_member = _{
    engine_stmt
  | iterations_stmt
  | population_stmt
  | mutation_stmt
  | description_stmt
  | data_field
}

engine_stmt     = { "engine:" ~ ident }
iterations_stmt = { "iterations:" ~ number }
population_stmt = { "population_size:" ~ number }
mutation_stmt   = { "mutation_strategy:" ~ ident }

// 5. benchmark_gate_def — pass/fail gate for a benchmark
benchmark_gate_def  = { "benchmark_gate" ~ ident ~ "{" ~ benchmark_gate_body ~ "}" }
benchmark_gate_body = { benchmark_gate_member* }
benchmark_gate_member = _{
    benchmark_stmt
  | tolerance_stmt
  | pass_criteria_stmt
  | description_stmt
  | data_field
}

benchmark_stmt     = { "benchmark:" ~ string_literal }
tolerance_stmt     = { "tolerance:" ~ number }
pass_criteria_stmt = { "pass_criteria:" ~ string_literal }

// 6. evolution_run_def — a complete evolution experiment record
evolution_run_def  = { "evolution_run" ~ ident ~ "{" ~ evolution_run_body ~ "}" }
evolution_run_body = { evolution_run_member* }
evolution_run_member = _{
    target_ref_stmt
  | optimizer_ref_stmt
  | dataset_ref_stmt
  | gate_ref_stmt
  | status_stmt
  | description_stmt
  | data_field
}

target_ref_stmt    = { "target:" ~ ident }
optimizer_ref_stmt = { "optimizer:" ~ ident }
dataset_ref_stmt   = { "dataset:" ~ ident }
gate_ref_stmt      = { "gate:" ~ ident }
status_stmt        = { "status:" ~ ident }

// 7. constraint_def — reusable named constraint
constraint_def      = { "constraint" ~ ident ~ "{" ~ constraint_def_body ~ "}" }
constraint_def_body = { constraint_def_member* }
constraint_def_member = _{
    type_stmt
  | threshold_stmt
  | enforcement_stmt
  | description_stmt
  | data_field
}

// ============================================================
// AGENT SYSTEM
// ============================================================

// 1. agent_def — autonomous agent with persona, model, capabilities, learning
agent_def  = { "agent" ~ ident ~ "{" ~ agent_body ~ "}" }
agent_body = { agent_member* }
agent_member = _{
    persona_stmt
  | model_ref_stmt
  | capabilities_stmt
  | learning_ref_stmt
  | backends_stmt
  | data_field
  | description_stmt
  | in_port
  | out_port
  | process_rule
}

persona_stmt      = { "persona:" ~ string_literal }
model_ref_stmt    = { "model:" ~ ident }
capabilities_stmt = { "capabilities:" ~ "[" ~ ident_list ~ "]" }
learning_ref_stmt = { "learning:" ~ ident }
backends_stmt     = { "backends:" ~ "[" ~ ident_list ~ "]" }

// 2. platform_def — messaging platform endpoint (terminal, telegram, discord, etc.)
platform_def  = { "platform" ~ ident ~ "{" ~ platform_body ~ "}" }
platform_body = { platform_member* }
platform_member = _{
    type_stmt
  | auth_stmt
  | format_stmt
  | endpoint_stmt
  | data_field
  | description_stmt
}

auth_stmt     = { "auth:" ~ string_literal }
format_stmt   = { "format:" ~ ident }
endpoint_stmt = { "endpoint:" ~ string_literal }

// 3. gateway_def — unified messaging gateway binding agent to platforms
gateway_def  = { "gateway" ~ ident ~ "{" ~ gateway_body ~ "}" }
gateway_body = { gateway_member* }
gateway_member = _{
    agent_ref_stmt
  | platforms_stmt
  | routes_stmt
  | data_field
  | description_stmt
  | in_port
  | out_port
  | process_rule
}

agent_ref_stmt  = { "agent:" ~ ident }
platforms_stmt  = { "platforms:" ~ "[" ~ ident_list ~ "]" }
routes_stmt     = { "routes:" ~ "[" ~ route_entry ~ ("," ~ route_entry)* ~ "]" }
route_entry     = { ident ~ "->" ~ ident }

// 4. execution_backend_def — runtime environment with resource limits
execution_backend_def  = { "execution_backend" ~ ident ~ "{" ~ exec_backend_body ~ "}" }
exec_backend_body      = { exec_backend_member* }
exec_backend_member = _{
    backend_type_stmt
  | connection_stmt
  | limits_stmt
  | data_field
  | description_stmt
}

backend_type_stmt = { "backend_type:" ~ ident }
connection_stmt   = { "connection:" ~ string_literal }
limits_stmt       = { "limits:" ~ "{" ~ limit_entry ~ ("," ~ limit_entry)* ~ "}" }
limit_entry       = { ident ~ ":" ~ expression }

// 5. skill_def — procedural knowledge unit with trigger and steps
skill_def  = { "skill" ~ ident ~ "{" ~ skill_body ~ "}" }
skill_body = { skill_member* }
skill_member = _{
    trigger_stmt
  | steps_stmt
  | status_stmt
  | improvement_stmt
  | data_field
  | description_stmt
}

trigger_stmt     = { "trigger:" ~ string_literal }
steps_stmt       = { "steps:" ~ "[" ~ string_list ~ "]" }
improvement_stmt = { "improvement:" ~ "{" ~ meta_pair_list ~ "}" }

// 6. learning_config_def — settings for skill generation and self-improvement
learning_config_def  = { "learning_config" ~ ident ~ "{" ~ learning_body ~ "}" }
learning_body        = { learning_member* }
learning_member = _{
    mode_stmt
  | skill_gen_stmt
  | memory_persist_stmt
  | session_search_stmt
  | self_improve_stmt
  | data_field
  | description_stmt
}

mode_stmt           = { "mode:" ~ ident }
skill_gen_stmt      = { "skill_generation:" ~ expression }
memory_persist_stmt = { "memory_persist:" ~ expression }
session_search_stmt = { "session_search:" ~ expression }
self_improve_stmt   = { "self_improve:" ~ expression }

// 7. cron_task_def — scheduled automation with platform delivery
cron_task_def  = { "cron_task" ~ ident ~ "{" ~ cron_body ~ "}" }
cron_body      = { cron_member* }
cron_member = _{
    schedule_stmt
  | agent_ref_stmt
  | platform_delivery_stmt
  | action_stmt
  | data_field
  | description_stmt
}

schedule_stmt           = { "schedule:" ~ string_literal }
platform_delivery_stmt  = { "deliver_to:" ~ ident }

// 8. model_config_def — LLM provider configuration with fallback chain
model_config_def  = { "model_config" ~ ident ~ "{" ~ model_config_body ~ "}" }
model_config_body = { model_config_member* }
model_config_member = _{
    provider_stmt
  | model_id_stmt
  | fallback_stmt
  | params_stmt
  | cost_limit_stmt
  | data_field
  | description_stmt
}

provider_stmt   = { "provider:" ~ ident }
model_id_stmt   = { "model_id:" ~ string_literal }
fallback_stmt   = { "fallback:" ~ ident }
params_stmt     = { "params:" ~ "{" ~ meta_pair_list ~ "}" }
cost_limit_stmt = { "cost_limit:" ~ expression }

// ============================================================
// VISUAL COMMUNICATION LAYER
// ============================================================

// 1. diagram_def — named visual artifact
diagram_def  = { "diagram" ~ ident ~ "{" ~ diagram_body ~ "}" }
diagram_body = { diagram_member* }
diagram_member = _{
    diagram_type_stmt
  | source_stmt
  | render_config_stmt
  | description_stmt
  | data_field
}

diagram_type_stmt  = { "type:" ~ ident }
render_config_stmt = { "render:" ~ ident }

// 2. preview_def — HTML component preview
preview_def  = { "preview" ~ ident ~ "{" ~ preview_body ~ "}" }
preview_body = { preview_member* }
preview_member = _{
    source_stmt
  | viewport_stmt
  | mode_stmt
  | render_config_stmt
  | description_stmt
  | data_field
}

viewport_stmt = { "viewport:" ~ ident }

// 3. annotation_def — markup layer on image
annotation_def  = { "annotation" ~ ident ~ "{" ~ annotation_body ~ "}" }
annotation_body = { annotation_member* }
annotation_member = _{
    target_ref_stmt
  | element_stmt
  | description_stmt
  | data_field
}

element_stmt = { "element:" ~ ident ~ "(" ~ meta_pair_list ~ ")" }

// 4. visual_review_def — review cycle
visual_review_def  = { "visual_review" ~ ident ~ "{" ~ visual_review_body ~ "}" }
visual_review_body = { visual_review_member* }
visual_review_member = _{
    target_ref_stmt
  | render_config_stmt
  | feedback_mode_stmt
  | description_stmt
  | data_field
}

feedback_mode_stmt = { "feedback_mode:" ~ ident }

// 5. screenshot_def — captured image with metadata
screenshot_def  = { "screenshot" ~ ident ~ "{" ~ screenshot_body ~ "}" }
screenshot_body = { screenshot_member* }
screenshot_member = _{
    path_stmt
  | source_stmt
  | tags_stmt
  | description_stmt
  | data_field
}

tags_stmt = { "tags:" ~ "[" ~ ident_list ~ "]" }

// 6. visual_search_def — semantic search query
visual_search_def  = { "visual_search" ~ ident ~ "{" ~ visual_search_body ~ "}" }
visual_search_body = { visual_search_member* }
visual_search_member = _{
    search_mode_stmt
  | query_stmt
  | tags_stmt
  | max_results_stmt
  | description_stmt
  | data_field
}

search_mode_stmt = { "search_mode:" ~ ident }
query_stmt       = { "query:" ~ string_literal }
max_results_stmt = { "max_results:" ~ number }

// 7. render_config_def — output configuration
render_config_def  = { "render_config" ~ ident ~ "{" ~ render_config_body ~ "}" }
render_config_body = { render_config_member* }
render_config_member = _{
    format_stmt
  | width_stmt
  | height_stmt
  | theme_stmt
  | scale_stmt
  | description_stmt
  | data_field
}

width_stmt  = { "width:" ~ number }
height_stmt = { "height:" ~ number }
theme_stmt  = { "theme:" ~ string_literal }
scale_stmt  = { "scale:" ~ number }

// ============================================================
// TERMINALS
// ============================================================

// Allow an optional trailing prime (foo') for "next value" notation.
ident          = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* ~ "'"? }
number         = @{ "-"? ~ ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)? }
string_literal = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" }
