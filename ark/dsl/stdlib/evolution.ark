// ARK Standard Library — Evolution Schema
// Defines struct and enum types for the agent self-evolution subsystem:
// optimization tiers, engines, data sources, fitness scoring, variants,
// constraints, benchmarks, and run tracking.

import stdlib.types

// ============================================================
// ENUMS
// ============================================================

// Risk-ordered optimization tiers (mirrors Hermes four-tier model)
enum EvolutionTier {
    skill,          // Tier 1 — SKILL.md procedural instruction files (lowest risk)
    tool_desc,      // Tier 2 — tool schema description fields
    system_prompt,  // Tier 3 — parameterized system prompt sections
    code            // Tier 4 — tool implementation code (highest risk)
}

// Available optimization engines
enum OptimizerEngine {
    gepa,       // Genetic-Pareto prompt evolution — reflective LLM mutation
    miprov2,    // Bayesian optimization for few-shot examples and instructions
    darwinian   // Git-based organism model for code-level evolution (Phase 4)
}

// Evaluation dataset sources
enum DataSource {
    synthetic,  // Generated by strong model reading skill and creating test cases
    session_db, // Mined from real usage sessions, LLM-as-judge scored
    golden,     // Hand-curated golden evaluation sets
    auto_eval   // Skill-specific automatic evaluation
}

// Constraint enforcement behavior on violation
enum EnforcementLevel {
    block,  // Hard failure — halt evolution and reject variant
    warn    // Soft failure — log violation but allow variant to proceed
}

// Lifecycle status of an evolution run
enum RunStatus {
    pending,    // Run created but not yet started
    running,    // Optimization loop in progress
    completed,  // Run finished successfully with best variant selected
    failed      // Run terminated due to constraint violation or error
}

// Mutation strategy applied during optimization
enum MutationStrategy {
    reflective, // Failure-analysis-informed targeted mutation (GEPA style)
    random,     // Stochastic mutation without failure analysis
    crossover   // Combine fragments from two high-fitness parent variants
}

// Fitness aggregation method across rubric dimensions
enum AggregationMethod {
    weighted_sum, // Sum of (weight * score) across all dimensions
    min,          // Minimum score across all dimensions (bottleneck)
    harmonic      // Harmonic mean — penalizes extreme low scores
}

// ============================================================
// STRUCTS
// ============================================================

// Composite fitness score across multiple rubric dimensions
struct FitnessScore {
    dimensions: [String],       // Ordered list of rubric dimension names
    weights: [Float],           // Per-dimension weights (must sum to 1.0)
    aggregation: AggregationMethod  // How to combine dimension scores
}

// A single evolved candidate with lineage tracking
struct Variant {
    content: String,    // The evolved text or code content
    fitness: Float,     // Aggregated fitness score in [0.0, 1.0]
    generation: Int,    // Generation number in which this variant was produced
    parent: String      // ID of the parent variant (empty string for seed)
}

// A safety or quality constraint applied to evolved variants
struct ConstraintDef {
    type: String,               // Constraint kind: size_limit, semantic_preservation, test_suite, caching_compat
    threshold: Float,           // Numeric threshold (e.g., 1.2 for 20% size growth limit)
    enforcement: EnforcementLevel  // block or warn on violation
}

// Result of a single benchmark gate evaluation
struct BenchmarkResult {
    benchmark: String,  // Benchmark identifier (e.g., TBLite, YC-Bench)
    score: Float,       // Score achieved by the variant on this benchmark
    passed: Bool        // Whether the variant cleared the gate threshold
}

// Outcome of a completed evolution run
struct RunResult {
    best_variant: Variant,          // Highest-fitness variant from the final generation
    fitness_trajectory: [Float],    // Per-generation best fitness (for convergence analysis)
    generations: Int,               // Total number of generations executed
    status: RunStatus               // Terminal status of the run
}

// Train / validation / test split ratios for an eval dataset
struct SplitRatio {
    train: Float,   // Fraction used for training (optimization signal)
    val: Float,     // Fraction used for validation (early stopping, hyperparams)
    test: Float     // Fraction used for final held-out evaluation (train+val+test must equal 1.0)
}

// A single dimension in an LLM-as-judge rubric
struct RubricDimension {
    name: String,       // Dimension identifier (e.g., procedure_adherence, conciseness)
    weight: Float,      // Contribution weight in aggregated fitness score
    description: String // Human-readable scoring criteria for this dimension
}
