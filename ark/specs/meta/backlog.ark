// Новая P1 — раздельное хранение класса и его инстансов.
// Сейчас ArkFile.items держит классы и instance'ы в одном плоском списке,
// связь Instance→Class только по строке class_name. Добавить индекс.
class SeparateInstanceStorageTask : Task {
  $data id:       String = "p1-separate-instance-storage"
  $data title:    String = "Parser: раздельное хранение класса и его инстансов"
  $data priority: Int [1..5] = 1
  $data status:   String = "done"
  $data phase:    String = "parser"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 1]{
    description: "Pure-additive индекс. Python: ArkFile.classes / .instances / .island_classes + helper instances_of(). Rust: classes_index / instances_index / island_classes_index (BTreeMap<String, usize>) + ArkFile::instances_of / ::class. Island-nested классы в отдельной per-island map (no collision). 4+4=8 тестов (pytest 42/42, cargo dsl 10/10)."
    pre: priority == 1
    post: status == "done"
  }
}

