// ARK Backlog — meta-spec, который ОЖИВЛЯЕТ список задач из CLAUDE.md.
//
// Идея: backlog — это не markdown-список, а остров в ARK DSL:
//   - Task       — одна работа с приоритетом/фазой/статусом
//   - Subagent   — исполнитель (general-purpose, Explore, reviewer...)
//   - Backlog    — остров-диспетчер, держит задачи и очередь
//   - Dispatch   — bridge из Task.artifacts в Subagent.assignment
//   - BacklogPlan — registry фаз
//   - ArkBacklog — живой instance, на котором идёт исполнение
//
// Стратегия: script — оркестрация, не SIMD. Приоритет 100 в Tick.
//
// После parse → verify → оркестратор поднимает ArkBacklog и прогоняет
// каждую ready-задачу через назначенного субагента (в терминах
// Claude Code это Task tool с соответствующим subagent_type).

import stdlib.types

// ============================================================
// СУБАГЕНТ — исполнитель задачи
// ============================================================

abstraction Subagent {
  $data name:     String
  $data role:     String = "executor"
  $data capacity: Int [0..10] = 1
  $data busy:     Int [0..10] = 0

  @in{ assignment: String, task_id: String }

  #process[strategy: script]{
    description: "Принять задачу: увеличить счётчик busy если есть ёмкость"
    pre: busy < capacity
    busy' = busy + 1
    post: busy <= capacity
  }

  @out[]{ report: String, status: String }

  invariant: busy >= 0
  invariant: busy <= capacity
}

class CodeSubagent : Subagent {
  $data name:     String = "general-purpose"
  $data role:     String = "executor"
  $data capacity: Int [0..10] = 4
  $data busy:     Int [0..10] = 0

  #process[strategy: script, priority: 100]{
    description: "Claude Code general-purpose агент: берёт ready-задачу и пишет код"
    pre: busy < capacity
    busy' = busy + 1
    post: busy <= capacity
  }

  @out[guaranteed: true]{ report: String, status: String }
}

class ExploreSubagent : Subagent {
  $data name:     String = "Explore"
  $data role:     String = "explorer"
  $data capacity: Int [0..10] = 2
  $data busy:     Int [0..10] = 0

  #process[strategy: script, priority: 90]{
    description: "Быстрый поиск по коду — отвечает на вопросы, не правит"
    pre: busy < capacity
    busy' = busy + 1
    post: busy <= capacity
  }
}

class ReviewSubagent : Subagent {
  $data name:     String = "feature-dev:code-reviewer"
  $data role:     String = "reviewer"
  $data capacity: Int [0..10] = 2
  $data busy:     Int [0..10] = 0

  #process[strategy: script, priority: 80]{
    description: "Ревью пул-реквеста: выдаёт только high-priority замечания"
    pre: busy < capacity
    busy' = busy + 1
    post: busy <= capacity
  }
}

class PlanSubagent : Subagent {
  $data name:     String = "Plan"
  $data role:     String = "planner"
  $data capacity: Int [0..10] = 1
  $data busy:     Int [0..10] = 0

  #process[strategy: script, priority: 95]{
    description: "Архитектор: проектирует план реализации задачи"
    pre: busy < capacity
    busy' = busy + 1
    post: busy <= capacity
  }
}

// ============================================================
// ЗАДАЧА — единица работы в бэклоге
// ============================================================

abstraction Task {
  $data id:       String
  $data title:    String
  $data priority: Int [1..5] = 3
  $data status:   String = "todo"
  $data phase:    String = "backlog"
  $data agent:    String = "general-purpose"

  @in{ depends_on: String, tick: DeltaTime }

  #process[strategy: script]{
    pre: priority >= 1
    pre: priority <= 5
  }

  @out[]{ artifacts: String, status: String }

  invariant: priority >= 1
  invariant: priority <= 5
}

// ============================================================
// ЗАДАЧИ PRIORITY 1 — Парсер / Codegen глубина
// ============================================================

class ProcessBodiesTask : Task {
  $data id:       String = "p1-process-bodies"
  $data title:    String = "Codegen: генерация тел #process"
  $data priority: Int [1..5] = 1
  $data status:   String = "done"
  $data phase:    String = "codegen"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 1]{
    description: "Сгенерировать тела #process из pre/post/assignment"
    pre: priority == 1
    post: status == "done"
  }

  @out[guaranteed: true]{ artifacts: String, status: String }
}

class SoAProcessAllTask : Task {
  $data id:       String = "p1-soa-process-all"
  $data title:    String = "Codegen: SoA batch process_all() с формулами"
  $data priority: Int [1..5] = 1
  $data status:   String = "done"
  $data phase:    String = "codegen"

  #process[strategy: script, priority: 1]{
    description: "VehicleBatch::process_all считает формулы, не TODO"
    post: status == "done"
  }
}

