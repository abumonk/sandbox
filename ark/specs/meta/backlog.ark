    post: status == "done"
  }
}

// Обнаружено при регрессионной проверке verify: specs/game/vehicle_physics.ark
// падает на "unexpected character ']'" в строке `#process[]{`. Грамматика
// требует хотя бы один meta-атрибут между квадратных скобок.
//
// Fix: meta_brackets: "[" meta_pair_list? "]" — сделан опциональным.
// Builder в ark_parser.py уже готов (items[0] if items else []).
// Добавлены 2 unit-теста: пустые скобки и отсутствие скобок вообще.
// vehicle_physics.ark теперь парсится дальше (упирается в RequiresStmtTask).
class EmptyProcessMetaTask : Task {
  $data id:       String = "p1-empty-process-meta"
  $data title:    String = "Parser: разрешить пустой #process[]{} без meta"
  $data priority: Int [1..5] = 2
  $data status:   String = "done"
  $data phase:    String = "parser"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 2]{
    description: "meta_pair_list сделан опциональным, 2 новых теста (30/30 зелёных). vehicle_physics.ark двигается дальше по парсеру."
    pre: priority == 2
    post: status == "done"
  }

  @out[guaranteed: true]{ artifacts: String, status: String }
}

// Обнаружено EmptyProcessMetaTask'ом: после разблокировки пустых [],
// vehicle_physics.ark упёрся в `requires:` — ключевое слово не
// поддержано в process_body. Семантически это precondition, поэтому
// простейшее решение — сделать алиас для `pre:`.
//
// Fix: grammar добавлен `requires_stmt: "requires:" expr`; builder
// возвращает {_stmt: "pre", expr} — landing в тот же pre-список.
// Unit-тест test_process_rule_requires_is_alias_for_pre зелёный.
// vehicle_physics.ark теперь упирается в следующий баг: `$data fuel`
// как префикс выражения (DataPrefixExprTask — ещё не заведён).
class RequiresStmtTask : Task {
  $data id:       String = "p1-requires-stmt"
  $data title:    String = "Parser: поддержать `requires:` как алиас для `pre:`"
  $data priority: Int [1..5] = 2
  $data status:   String = "done"
  $data phase:    String = "parser"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 2]{
    description: "requires_stmt landing в pre-список, 1 новый тест (31/31 зелёных)"
    pre: priority == 2
    post: status == "done"
  }

  @out[guaranteed: true]{ artifacts: String, status: String }
}

// Обнаружено RequiresStmtTask'ом: после разблокировки `requires:`,
// vehicle_physics.ark упирается в `$data fuel > 0` — префикс `$data`
// перед идентификатором в выражении. В декларациях `$data` — ключевое
// слово, в выражениях парсер его не знает. Решение: принять `$data IDENT`
// как явное указание на data-поле, алиас голого IDENT.
//
// Fix: atom расширен `"$data" IDENT -> data_ref_expr`; builder lower'ит
// в обычный ident-expr — `$data x` и `x` дают идентичный AST. Добавлены
// 2 теста (alias + equivalence). vehicle_physics.ark теперь упирается
// в `throttle in [0..1]` — range-syntax внутри выражения, отдельный баг.
class DataPrefixExprTask : Task {
  $data id:       String = "p1-data-prefix-expr"
  $data title:    String = "Parser: `$data IDENT` в выражениях как алиас IDENT"
  $data priority: Int [1..5] = 2
  $data status:   String = "done"
  $data phase:    String = "parser"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 2]{
    description: "$data IDENT → ident_expr, 2 новых теста (33/33 зелёных)"
    pre: priority == 2
    post: status == "done"
  }

  @out[guaranteed: true]{ artifacts: String, status: String }
}

