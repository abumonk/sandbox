class IslandTickLoopTask : Task {
  $data id:       String = "p4-island-tick-loop"
  $data title:    String = "Runtime: загрузка island → tick loop из root.ark"
  $data priority: Int [1..5] = 4
  $data status:   String = "done"
  $data phase:    String = "runtime"
  $data agent:    String = "Plan"

  #process[strategy: script, priority: 4]{
    description: "runtime/src/runtime.rs: Runtime { slots: [IslandSlot{name,priority,tick_count}], frame, ecs }. from_ark_file() собирает островные слоты из Item::Island, подтягивает priority из registry (fallback 999), сортирует (priority asc, name asc). tick() инкрементит frame + каждый слот. Runtime implements WindowApp — run_frames() из WgpuWindowTask'а драйвит его без реального окна. Body-level #process execution отложено (нужен codegen integration). 5 тестов (38/38 cargo: 5 window + 5 ecs + 5 runtime + 5 orchestrator + 10 dsl + 5 codegen + 2 verify + 6 orchestrator)."
    pre: priority == 4
    post: status == "done"
  }
}

// ============================================================
// ЗАДАЧИ PRIORITY 5 — перенос на Rust
// ============================================================

class PestParseRsTask : Task {
  $data id:       String = "p5-pest-parse-rs"
  $data title:    String = "Rust: dsl/src/parse.rs — pest Pairs → ArkFile AST"
  $data priority: Int [1..5] = 1
  $data status:   String = "done"
  $data phase:    String = "parser"

  #process[strategy: script, priority: 1]{
    description: "Walker над pest Pairs, precedence-climbing expressions"
    post: status == "done"
  }
}

class RustCodegenTask : Task {
  $data id:       String = "p5-rust-codegen"
  $data title:    String = "Rust: codegen/src — entity → Rust struct"
  $data priority: Int [1..5] = 2
  $data status:   String = "done"
  $data phase:    String = "codegen"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 2]{
    description: "codegen/src/lib.rs 282 loc, 5 тестов зелёных. SoA вынесен отдельно."
    post: status == "done"
  }
}

class SmtLibTask : Task {
  $data id:       String = "p5-smt-lib"
  $data title:    String = "Rust: verify/src — AST → SMT-LIB2 text"
  $data priority: Int [1..5] = 2
  $data status:   String = "done"
  $data phase:    String = "verify"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 2]{
    description: "ark-verify крейт: ArkFile→.smt2 текст, без libz3. 2 теста зелёные."
    post: status == "done"
  }
}

class OrchestratorRsTask : Task {
  $data id:       String = "p5-orchestrator-rs"
  $data title:    String = "Rust: orchestrator/src — читает root.ark, запускает DAG"
  $data priority: Int [1..5] = 3
  $data status:   String = "done"
  $data phase:    String = "runtime"
  $data agent:    String = "general-purpose"

  #process[strategy: script, priority: 3]{
    description: "ark-orchestrator крейт: lib+bin, parse→verify→codegen+DAG. 3 теста зелёных. Попутно fixed cmp_op word-boundary для 'in'."
    post: status == "done"
  }
}

// ============================================================
// БЭКЛОГ — живой остров с диспетчеризацией задач
// ============================================================

island Backlog {
  strategy: script
  description: "Очередь задач ARK. Диспатчит ready-задачи свободным субагентам."

  contains: [
    SeparateInstanceStorageTask,
    ProcessBodiesTask,
    SoAProcessAllTask,
    DefaultValuesTask,
    ParserRobustnessTask,
    ImportResolutionTask,
    StdlibKeywordsTask,
    UnitTestsTask,
    ParserBugfixTask,
    EmptyProcessMetaTask,
    RequiresStmtTask,
    DataPrefixExprTask,
    VerifyFullExprTask,
    BridgeContractTask,
    TemporalBMCTask,
    ArkDiffTask,
    OrchestratorRootTask,
    FileWatcherTask,
    ClaudeTaskBridgeTask,
    WgpuWindowTask,
    WgpuBackendTask,
    HecsEcsTask,
    IslandTickLoopTask,
    PestParseRsTask,
    RustCodegenTask,
    SmtLibTask,
    OrchestratorRsTask
  ]

  $data total:      Int [0..100] = 27
  $data done_count: Int [0..100] = 26
  $data in_flight:  Int [0..100] = 0
  $data blocked:    Int [0..100] = 0

  @in{ tick: DeltaTime, agent_report: String }

  #process[strategy: script, priority: 100]{
    description: "Tick: найти ready-задачу, назначить свободному агенту, продвинуть"
    pre: done_count <= total
    pre: in_flight >= 0
    pre: in_flight < total
    pre: blocked >= 0

    in_flight' = in_flight + 1

    post: done_count <= total
    post: in_flight' <= total
  }

  @out[guaranteed: true]{ progress: String, board: String }

  invariant: done_count >= 0
  invariant: done_count <= total
  invariant: in_flight >= 0
  invariant: blocked >= 0
}

// ============================================================
// МОСТ — поток: Task → Subagent
// ============================================================

bridge Dispatch {
  from: Task.artifacts
  to:   CodeSubagent.assignment

  contract {
    invariant: status == "ready" or status == "in_progress"
  }
}

bridge Review {
  from: CodeSubagent.report
  to:   ReviewSubagent.assignment

  contract {
    invariant: status == "done"
  }
}

// ============================================================
// РЕЕСТР — очередь исполнения по фазам
// ============================================================

registry BacklogPlan {
  register SeparateInstanceStorageTask { phase: parser, priority: 1 }
  register PestParseRsTask       { phase: parser,  priority: 1 }
  register ProcessBodiesTask     { phase: codegen, priority: 1 }
  register SoAProcessAllTask     { phase: codegen, priority: 1 }
  register DefaultValuesTask     { phase: codegen, priority: 1 }
  register ImportResolutionTask  { phase: parser,  priority: 1 }
  register ParserRobustnessTask  { phase: parser,  priority: 2 }
  register EmptyProcessMetaTask  { phase: parser,  priority: 2 }
  register RequiresStmtTask      { phase: parser,  priority: 2 }
  register DataPrefixExprTask    { phase: parser,  priority: 2 }
  register RustCodegenTask       { phase: codegen, priority: 2 }
  register SmtLibTask            { phase: verify,  priority: 2 }
  register UnitTestsTask         { phase: tests,   priority: 2 }
  register VerifyFullExprTask    { phase: verify,  priority: 2 }
  register BridgeContractTask    { phase: verify,  priority: 2 }
  register OrchestratorRootTask  { phase: runtime, priority: 2 }
  register OrchestratorRsTask    { phase: runtime, priority: 3 }
  register TemporalBMCTask       { phase: verify,  priority: 3 }
  register ArkDiffTask           { phase: tools,   priority: 3 }
  register FileWatcherTask       { phase: runtime, priority: 3 }
  register ClaudeTaskBridgeTask  { phase: runtime, priority: 3 }
  register WgpuWindowTask        { phase: runtime, priority: 4 }
  register WgpuBackendTask       { phase: runtime, priority: 4 }
  register HecsEcsTask           { phase: runtime, priority: 4 }
  register IslandTickLoopTask    { phase: runtime, priority: 4 }
}

// ============================================================
// ИНСТАНС — живая очередь на которой идёт исполнение
// ============================================================

instance ArkBacklog : Backlog {
  total      = 27
  done_count = 26
  in_flight  = 0
  blocked    = 0
}

// ============================================================
// ВЕРИФИКАЦИЯ — топологические инварианты бэклога
// ============================================================

verify Backlog {
  check done_never_negative:
    ArkBacklog.done_count >= 0

  check done_bounded:
    ArkBacklog.done_count <= ArkBacklog.total

  check parser_before_codegen:
    PestParseRsTask.priority <= RustCodegenTask.priority

  check priority_well_formed:
    ProcessBodiesTask.priority >= 1 and OrchestratorRsTask.priority <= 5

  check process_bodies_done:
    ProcessBodiesTask.priority == 1

  check dispatch_contract:
    DefaultValuesTask.status == "ready" or DefaultValuesTask.status == "done"
}
