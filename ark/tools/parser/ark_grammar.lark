// ARK DSL Grammar — Lark EBNF
// Полная грамматика для парсинга .ark файлов

start: (import_stmt | item)*

// ============================================================
// TOP LEVEL
// ============================================================

import_stmt: "import" dotted_path

item: abstraction_def
    | class_def
    | instance_def
    | island_def
    | bridge_def
    | registry_def
    | verify_def
    | primitive_def
    | struct_def
    | enum_def
    | expression_def
    | predicate_def
    | role_def
    | studio_def
    | command_def
    | hook_def
    | rule_def
    | template_def
    | evolution_target_def
    | eval_dataset_def
    | fitness_function_def
    | optimizer_def
    | benchmark_gate_def
    | evolution_run_def
    | constraint_def
    | agent_def
    | platform_def
    | gateway_def
    | execution_backend_def
    | skill_def
    | learning_config_def
    | cron_task_def
    | model_config_def
    | diagram_def
    | preview_def
    | annotation_def
    | visual_review_def
    | screenshot_def
    | visual_search_def
    | render_config_def

// ============================================================
// FOUR PRIMITIVES
// ============================================================

in_port: "@in" "{" typed_field_list "}"

process_rule: "#process" meta_brackets? "{" process_body "}"

out_port: "@out" empty_meta? "{" typed_field_list "}"
empty_meta: "[" meta_pair_list? "]"

data_field: "$data" IDENT ":" type_expr constraint? default_value?

// ============================================================
// PROCESS BODY
// ============================================================

process_body: process_stmt*

process_stmt: pre_stmt
            | post_stmt
            | requires_stmt
            | description_stmt
            | for_all_stmt
            | condition_stmt
            | assignment
            | expr

pre_stmt: "pre:" expr
post_stmt: "post:" expr
requires_stmt: "requires:" expr

// ============================================================
// ENTITIES
// ============================================================

abstraction_def: "abstraction" IDENT inherits? "{" entity_body "}"
class_def: "class" IDENT inherits? "{" entity_body "}"

entity_body: entity_member*

entity_member: in_port
             | out_port
             | process_rule
             | data_field
             | invariant_stmt
             | temporal_stmt
             | description_stmt

instance_def: "instance" IDENT ":" IDENT "{" assignment* "}"

inherits: ":" ident_list

// ============================================================
// ISLANDS
// ============================================================

island_def: "island" IDENT "{" island_body "}"

island_body: island_member*

island_member: strategy_stmt
             | memory_stmt
             | contains_stmt
             | description_stmt
             | in_port
             | out_port
             | process_rule
             | class_def
             | data_field
             | invariant_stmt
             | temporal_stmt

// ============================================================
// BRIDGES
// ============================================================

bridge_def: "bridge" IDENT "{" bridge_body "}"

bridge_body: from_stmt to_stmt contract_block?

from_stmt: "from:" dotted_path
to_stmt: "to:" dotted_path

contract_block: "contract" "{" contract_member* "}"
contract_member: invariant_stmt | temporal_stmt

// ============================================================
// REGISTRY
// ============================================================

registry_def: "registry" IDENT "{" register_stmt* "}"
register_stmt: "register" IDENT "{" meta_pair_list "}"

// ============================================================
// VERIFICATION
// ============================================================

verify_def: "verify" IDENT "{" check_stmt* "}"
check_stmt: "check" IDENT ":" expr

// ============================================================
// EXPRESSION & PREDICATE DEFINITIONS
// ============================================================

expression_def: "expression" def_ident "{" expression_body "}"
predicate_def: "predicate" def_ident "{" predicate_body "}"

// Kebab-case name for expression / predicate definitions (e.g. is-empty, starts-with)
def_ident: IDENT ("-" IDENT)*

expression_body: "in:" typed_field_list "out:" type_expr "chain:" expr
predicate_body: "in:" typed_field_list "check:" expr

// ============================================================
// STDLIB TYPE DECLARATIONS
// ============================================================

primitive_def: "primitive" IDENT

struct_def: "struct" IDENT "{" struct_field_list? "}"
struct_field_list: struct_field ("," struct_field)* ","?
struct_field: IDENT ":" type_expr

enum_def: "enum" IDENT "{" enum_variant_list? "}"
enum_variant_list: enum_variant ("," enum_variant)* ","?
enum_variant: IDENT ("(" enum_variant_params ")")?
enum_variant_params: enum_variant_param ("," enum_variant_param)*
enum_variant_param: IDENT ":" type_expr -> enum_param_typed
                  | IDENT                -> enum_param_bare

// ============================================================
// STATEMENTS
// ============================================================

strategy_stmt: "strategy:" IDENT
memory_stmt: "memory:" "{" memory_entry ("," memory_entry)* "}"
memory_entry: IDENT "(" expr ("," expr)* ")"
contains_stmt: "contains:" "[" ident_list "]"
description_stmt: "description:" STRING
invariant_stmt: "invariant:" expr
temporal_stmt: "temporal:" expr
assignment: dotted_path_or_ident "=" expr

// ============================================================
// EXPRESSIONS
// ============================================================

?expr: pipe_expr

?pipe_expr: or_expr ("|>" pipe_stage)*
pipe_stage: pipe_fn_ident "(" expr_list? ")"
          | pipe_fn_ident
pipe_fn_ident: IDENT ("-" IDENT)*

?or_expr: and_expr ("or" and_expr)*
?and_expr: cmp_expr ("and" cmp_expr)*
?cmp_expr: add_expr (CMP_OP add_expr)*
?add_expr: mul_expr (ADD_OP mul_expr)*
?mul_expr: unary_expr (MUL_OP unary_expr)*

?unary_expr: TEMPORAL_OP unary_expr           -> temporal_expr
           | "not" unary_expr                 -> not_expr
           | atom

?atom: "true"                                 -> true_expr
     | "false"                                -> false_expr
     | "$data" IDENT                          -> data_ref_expr
     | var_ref
     | prop_ref
     | idx_ref
     | nested_ref
     | fn_call
     | dotted_path                            -> path_expr
     | IDENT                                  -> ident_expr
     | NUMBER                                 -> number_expr
     | STRING                                 -> string_expr
     | "(" expr ")"                           -> paren_expr
     | "[" expr_list? "]"                     -> array_expr
     | for_all_expr

var_ref: "@" IDENT
prop_ref: "[" IDENT ("." IDENT)+ "]"
idx_ref: "#" IDENT "[" NUMBER "]"
nested_ref: "{" expr "}"

fn_call: dotted_path_or_ident "(" expr_list? ")"

for_all_expr: "for_all" IDENT "as" IDENT ("where" expr)? ":" (expr | "{" process_body "}")
for_all_stmt: "for_all" IDENT "as" IDENT ("where" expr)? ":" (assignment | "{" process_body "}")

condition_stmt: "condition" expr ":" (assignment | "{" process_body "}")

// ============================================================
// TYPES
// ============================================================

type_expr: IDENT "<" type_expr ">"            -> generic_type
         | "[" type_expr ":" type_expr "]"    -> map_type
         | "[" type_expr (";" NUMBER)? "]"    -> array_type
         | "{" ident_list "}"                 -> inline_enum_type
         | IDENT                              -> named_type

// ============================================================
// CONSTRAINTS
// ============================================================

constraint: "[" expr ".." expr "]"            -> range_constraint
          | "{" expr_list "}"                 -> enum_constraint

default_value: "=" expr

// ============================================================
// META
// ============================================================

meta_brackets: "[" meta_pair_list? "]"
meta_pair_list: meta_pair ("," meta_pair)*
meta_pair: IDENT ":" expr

// ============================================================
// LISTS
// ============================================================

typed_field_list: (typed_field ("," typed_field)*)?
typed_field: IDENT ":" type_expr

ident_list: IDENT ("," IDENT)*
expr_list: expr ("," expr)*

dotted_path: IDENT ("." IDENT)+
dotted_path_or_ident: IDENT ("." IDENT)*

// ============================================================
// STUDIO HIERARCHY
// ============================================================

// 1. role — specialist role definition
role_def: "role" IDENT inherits? "{" role_body "}"
role_body: role_member*
role_member: tier_stmt
           | responsibility_stmt
           | escalates_to_stmt
           | skills_stmt
           | tools_stmt
           | data_field
           | description_stmt
           | in_port
           | out_port
           | process_rule

tier_stmt: "tier:" expr
responsibility_stmt: "responsibility:" STRING
escalates_to_stmt: "escalates_to:" IDENT
skills_stmt: "skills:" "[" ident_list "]"
tools_stmt: "tools:" "[" ident_list "]"

// 2. studio — island grouping roles into tiers
studio_def: "studio" IDENT "{" studio_body "}"
studio_body: studio_member*
studio_member: tier_group
             | contains_stmt
             | description_stmt
             | data_field
             | invariant_stmt
             | process_rule
             | bridge_def

tier_group: "tier" expr "{" ident_list "}"

// 3. command — workflow slash-command binding
command_def: "command" IDENT "{" command_body "}"
command_body: command_member*
command_member: phase_stmt
              | prompt_stmt
              | role_ref_stmt
              | output_stmt
              | description_stmt
              | data_field

phase_stmt: "phase:" IDENT
prompt_stmt: "prompt:" STRING
role_ref_stmt: "role:" IDENT
output_stmt: "output:" IDENT

// 4. hook — event-driven rule
hook_def: "hook" IDENT "{" hook_body "}"
hook_body: hook_member*
hook_member: event_stmt
           | pattern_stmt
           | action_stmt
           | description_stmt
           | data_field

event_stmt: "event:" IDENT
pattern_stmt: "pattern:" STRING
action_stmt: "action:" STRING

// 5. rule — path-scoped policy
rule_def: "rule" IDENT "{" rule_body "}"
rule_body: rule_member*
rule_member: path_stmt
           | constraint_stmt_rule
           | severity_stmt
           | description_stmt
           | data_field

path_stmt: "path:" STRING
constraint_stmt_rule: "constraint:" STRING
severity_stmt: "severity:" IDENT

// 6. template — document skeleton
template_def: "template" IDENT "{" template_body "}"
template_body: template_member*
template_member: sections_stmt
               | bound_to_stmt
               | description_stmt
               | data_field

sections_stmt: "sections:" "[" string_list "]"
bound_to_stmt: "bound_to:" IDENT
string_list: STRING ("," STRING)*

// ============================================================
// EVOLUTION SYSTEM
// ============================================================

// 1. evolution_target_def — model or artifact to be evolved
evolution_target_def: "evolution_target" IDENT "{" evolution_target_body "}"
evolution_target_body: evolution_target_member*
evolution_target_member: tier_stmt
                       | file_ref_stmt
                       | constraints_block
                       | description_stmt
                       | data_field

file_ref_stmt: "file_ref:" STRING
constraints_block: "constraints" "{" constraint_item* "}"
constraint_item: constraint_item_member*
constraint_item_member: name_stmt
                      | type_stmt
                      | threshold_stmt
                      | enforcement_stmt

name_stmt: "name:" STRING
type_stmt: "type:" IDENT
threshold_stmt: "threshold:" expr
enforcement_stmt: "enforcement:" IDENT

// 2. eval_dataset_def — dataset used to evaluate evolved artifacts
eval_dataset_def: "eval_dataset" IDENT "{" eval_dataset_body "}"
eval_dataset_body: eval_dataset_member*
eval_dataset_member: source_stmt
                   | split_stmt
                   | scoring_rubric_stmt
                   | description_stmt
                   | data_field

source_stmt: "source:" STRING
split_stmt: "split:" "{" split_entry ("," split_entry)* ","? "}"
split_entry: IDENT ":" NUMBER
scoring_rubric_stmt: "scoring_rubric:" STRING

// 3. fitness_function_def — multi-dimensional scoring function
fitness_function_def: "fitness_function" IDENT "{" fitness_function_body "}"
fitness_function_body: fitness_function_member*
fitness_function_member: dimension_stmt
                       | aggregation_stmt
                       | description_stmt
                       | data_field

dimension_stmt: "dimension" IDENT "{" dimension_body "}"
dimension_body: dimension_member*
dimension_member: weight_stmt
                | metric_stmt
dimension_body_empty: dimension_member*
weight_stmt: "weight:" NUMBER
metric_stmt: "metric:" STRING
aggregation_stmt: "aggregation:" IDENT

// 4. optimizer_def — search/optimization engine configuration
optimizer_def: "optimizer" IDENT "{" optimizer_body "}"
optimizer_body: optimizer_member*
optimizer_member: engine_stmt
                | iterations_stmt
                | population_stmt
                | mutation_stmt
                | description_stmt
                | data_field

engine_stmt: "engine:" IDENT
iterations_stmt: "iterations:" NUMBER
population_stmt: "population_size:" NUMBER
mutation_stmt: "mutation_strategy:" IDENT

// 5. benchmark_gate_def — pass/fail gate for a benchmark
benchmark_gate_def: "benchmark_gate" IDENT "{" benchmark_gate_body "}"
benchmark_gate_body: benchmark_gate_member*
benchmark_gate_member: benchmark_stmt
                     | tolerance_stmt
                     | pass_criteria_stmt
                     | description_stmt
                     | data_field

benchmark_stmt: "benchmark:" STRING
tolerance_stmt: "tolerance:" NUMBER
pass_criteria_stmt: "pass_criteria:" STRING

// 6. evolution_run_def — a complete evolution experiment record
evolution_run_def: "evolution_run" IDENT "{" evolution_run_body "}"
evolution_run_body: evolution_run_member*
evolution_run_member: target_ref_stmt
                    | optimizer_ref_stmt
                    | dataset_ref_stmt
                    | gate_ref_stmt
                    | status_stmt
                    | description_stmt
                    | data_field

target_ref_stmt: "target:" IDENT
optimizer_ref_stmt: "optimizer:" IDENT
dataset_ref_stmt: "dataset:" IDENT
gate_ref_stmt: "gate:" IDENT
status_stmt: "status:" IDENT

// 7. constraint_def — reusable named constraint
constraint_def: "constraint" IDENT "{" constraint_def_body "}"
constraint_def_body: constraint_def_member*
constraint_def_member: type_stmt
                     | threshold_stmt
                     | enforcement_stmt
                     | description_stmt
                     | data_field

// ============================================================
// AGENT SYSTEM
// ============================================================

// 1. agent_def — autonomous agent with persona, model, capabilities, learning
agent_def: "agent" IDENT "{" agent_body "}"
agent_body: agent_member*
agent_member: persona_stmt
            | model_ref_stmt
            | capabilities_stmt
            | learning_ref_stmt
            | backends_stmt
            | data_field
            | description_stmt
            | in_port
            | out_port
            | process_rule

persona_stmt: "persona:" STRING
model_ref_stmt: "model:" IDENT
capabilities_stmt: "capabilities:" "[" ident_list "]"
learning_ref_stmt: "learning:" IDENT
backends_stmt: "backends:" "[" ident_list "]"

// 2. platform_def — messaging platform endpoint (terminal, telegram, discord, etc.)
platform_def: "platform" IDENT "{" platform_body "}"
platform_body: platform_member*
platform_member: type_stmt
               | auth_stmt
               | format_stmt
               | endpoint_stmt
               | data_field
               | description_stmt

auth_stmt: "auth:" STRING
format_stmt: "format:" IDENT
endpoint_stmt: "endpoint:" STRING

// 3. gateway_def — unified messaging gateway binding agent to platforms
gateway_def: "gateway" IDENT "{" gateway_body "}"
gateway_body: gateway_member*
gateway_member: agent_ref_stmt
              | platforms_stmt
              | routes_stmt
              | data_field
              | description_stmt
              | in_port
              | out_port
              | process_rule

agent_ref_stmt: "agent:" IDENT
platforms_stmt: "platforms:" "[" ident_list "]"
routes_stmt: "routes:" "[" route_entry ("," route_entry)* "]"
route_entry: IDENT "->" IDENT

// 4. execution_backend_def — runtime environment with resource limits
execution_backend_def: "execution_backend" IDENT "{" exec_backend_body "}"
exec_backend_body: exec_backend_member*
exec_backend_member: backend_type_stmt
                   | connection_stmt
                   | limits_stmt
                   | data_field
                   | description_stmt

backend_type_stmt: "backend_type:" IDENT
connection_stmt: "connection:" STRING
limits_stmt: "limits:" "{" limit_entry ("," limit_entry)* "}"
limit_entry: IDENT ":" expr

// 5. skill_def — procedural knowledge unit with trigger and steps
skill_def: "skill" IDENT "{" skill_body "}"
skill_body: skill_member*
skill_member: trigger_stmt
            | steps_stmt
            | status_stmt
            | improvement_stmt
            | data_field
            | description_stmt

trigger_stmt: "trigger:" STRING
steps_stmt: "steps:" "[" string_list "]"
improvement_stmt: "improvement:" "{" meta_pair_list "}"

// 6. learning_config_def — settings for skill generation and self-improvement
learning_config_def: "learning_config" IDENT "{" learning_body "}"
learning_body: learning_member*
learning_member: mode_stmt
               | skill_gen_stmt
               | memory_persist_stmt
               | session_search_stmt
               | self_improve_stmt
               | data_field
               | description_stmt

mode_stmt: "mode:" IDENT
skill_gen_stmt: "skill_generation:" expr
memory_persist_stmt: "memory_persist:" expr
session_search_stmt: "session_search:" expr
self_improve_stmt: "self_improve:" expr

// 7. cron_task_def — scheduled automation with platform delivery
cron_task_def: "cron_task" IDENT "{" cron_body "}"
cron_body: cron_member*
cron_member: schedule_stmt
           | agent_ref_stmt
           | platform_delivery_stmt
           | action_stmt
           | data_field
           | description_stmt

schedule_stmt: "schedule:" STRING
platform_delivery_stmt: "deliver_to:" IDENT

// 8. model_config_def — LLM provider configuration with fallback chain
model_config_def: "model_config" IDENT "{" model_config_body "}"
model_config_body: model_config_member*
model_config_member: provider_stmt
                   | model_id_stmt
                   | fallback_stmt
                   | params_stmt
                   | cost_limit_stmt
                   | data_field
                   | description_stmt

provider_stmt: "provider:" IDENT
model_id_stmt: "model_id:" STRING
fallback_stmt: "fallback:" IDENT
params_stmt: "params:" "{" meta_pair_list "}"
cost_limit_stmt: "cost_limit:" expr

// ============================================================
// VISUAL COMMUNICATION LAYER
// ============================================================

// 7. diagram_def — named visual artifact
diagram_def: "diagram" IDENT "{" diagram_body "}"
diagram_body: diagram_member*
diagram_member: diagram_type_stmt
              | source_stmt
              | render_config_stmt
              | description_stmt
              | data_field

diagram_type_stmt: "type:" IDENT
render_config_stmt: "render:" IDENT

// 8. preview_def — HTML component preview
preview_def: "preview" IDENT "{" preview_body "}"
preview_body: preview_member*
preview_member: source_stmt
              | viewport_stmt
              | mode_stmt
              | render_config_stmt
              | description_stmt
              | data_field

viewport_stmt: "viewport:" IDENT

// 9. annotation_def — markup layer on image
annotation_def: "annotation" IDENT "{" annotation_body "}"
annotation_body: annotation_member*
annotation_member: target_ref_stmt
                 | element_stmt
                 | description_stmt
                 | data_field

element_stmt: "element:" IDENT "(" meta_pair_list ")"

// 10. visual_review_def — review cycle
visual_review_def: "visual_review" IDENT "{" visual_review_body "}"
visual_review_body: visual_review_member*
visual_review_member: target_ref_stmt
                    | render_config_stmt
                    | feedback_mode_stmt
                    | description_stmt
                    | data_field

feedback_mode_stmt: "feedback_mode:" IDENT

// 11. screenshot_def — captured image with metadata
screenshot_def: "screenshot" IDENT "{" screenshot_body "}"
screenshot_body: screenshot_member*
screenshot_member: path_stmt
                 | source_stmt
                 | tags_stmt
                 | description_stmt
                 | data_field

tags_stmt: "tags:" "[" ident_list "]"

// 12. visual_search_def — semantic search query
visual_search_def: "visual_search" IDENT "{" visual_search_body "}"
visual_search_body: visual_search_member*
visual_search_member: search_mode_stmt
                    | query_stmt
                    | tags_stmt
                    | max_results_stmt
                    | description_stmt
                    | data_field

search_mode_stmt: "search_mode:" IDENT
query_stmt: "query:" STRING
max_results_stmt: "max_results:" NUMBER

// 13. render_config_def — output configuration
render_config_def: "render_config" IDENT "{" render_config_body "}"
render_config_body: render_config_member*
render_config_member: format_stmt
                    | width_stmt
                    | height_stmt
                    | theme_stmt
                    | scale_stmt
                    | description_stmt
                    | data_field

width_stmt: "width:" NUMBER
height_stmt: "height:" NUMBER
theme_stmt: "theme:" STRING
scale_stmt: "scale:" NUMBER

// ============================================================
// TERMINALS
// ============================================================

CMP_OP: "==" | "!=" | "<=" | ">=" | "<" | ">" | "in" | "→"
ADD_OP: "+" | "-"
MUL_OP: "*" | "/" | "%"
TEMPORAL_OP: "□" | "◇" | "○" | "¬" | "∧" | "∨"

IDENT: /[a-zA-Z_][a-zA-Z0-9_']*/

NUMBER: /\-?[0-9]+(\.[0-9]+)?/

STRING: "\"" /[^"]*/ "\""

// ============================================================
// WHITESPACE & COMMENTS
// ============================================================

%import common.WS
%ignore WS
%ignore /\/\/[^\n]*/
%ignore /\/\*[\s\S]*?\*\//
