+
+def _evo_tooltip(item: dict) -> dict:
+    """Extract key tooltip properties from an evolution AST item."""
+    props = {}
+    kind = item.get("kind", "")
+
+    if kind == "evolution_target":
+        if item.get("tier") is not None:
+            props["tier"] = str(item["tier"])
